<Page x:Class="Login.View.Sing"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Login.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Sing">

    <Grid Background="White" Margin="0,0,207,-16">
        <!-- Correo -->
        <TextBlock Text="Correo electrónico:" Margin="52,105,331,345" FontFamily="Arial Black"/>
        <TextBox x:Name="txtcorreo" 
                FontSize="14"
                Margin="53,126,363,305"/>

        <!-- Usuario -->
        <TextBlock Text="Nombre de usuario:" Margin="52,176,331,274" FontFamily="Arial Black"/>
        <TextBox x:Name="txtnombre" 
                FontSize="14"
                Margin="52,197,363,234"/>

        <!-- Contraseña -->
        <TextBlock Text="Contraseña:" Margin="329,105,54,345" FontFamily="Arial Black"/>
        <PasswordBox x:Name="txtcontraseña" 
                FontSize="14"
                Margin="329,126,92,305"/>

        <!-- Confirmar Contraseña -->
        <TextBlock Text="Confirmar contraseña:" Margin="329,176,54,274" FontFamily="Arial Black"/>
        <PasswordBox x:Name="txtconfirmar" 
                FontSize="14"
                Margin="329,197,92,234"/>

        <!-- Botones -->
        <Grid Margin="44,279,339,147">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnagregarusuario"
                    Grid.Column="2"
                    Content="Agregar Usuario"
                    FontSize="16"
                    Foreground="Black"
                    BorderThickness="0"
                    Click="btnSignUp_Click" Margin="50,14,-104,-25" FontFamily="Arial Black"/>
        </Grid>

    </Grid>
</Page>
