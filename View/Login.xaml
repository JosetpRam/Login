<Page x:Class="Login.View.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Login.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Login">

    <Grid Margin="0,0,330,132" Background="White">
        <Label Content="Usuario" HorizontalAlignment="Left" Margin="24,29,0,0" VerticalAlignment="Top" Height="36" Width="85" Background="White" FontFamily="Arial Black" FontSize="16"/>
        <TextBox x:Name="txtusuario" HorizontalAlignment="Left" Margin="24,70,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="149" Height="21"/>
        <Label Content="Password" HorizontalAlignment="Left" Margin="24,171,0,0" VerticalAlignment="Top" FontFamily="Arial Black" FontSize="16" Background="White"/>
        <Button x:Name="btnlogin" Content="Login" HorizontalAlignment="Left" Margin="234,123,0,0" VerticalAlignment="Top" Height="46" Width="124" FontFamily="Arial Black" FontSize="16"/>
        <TextBox HorizontalAlignment="Left" Margin="24,204,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="149" Height="21"/>

    </Grid>
</Page>
