<Window x:Class="Login.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Login"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button x:Name="btnlogin" Content="Login" HorizontalAlignment="Left" Margin="62,68,0,0" VerticalAlignment="Top" Height="80" Width="148" Command="{Binding LoginCommand}"/>
        <Button x:Name="btnagregar" Content="Agregar Usuarios" HorizontalAlignment="Left" Margin="62,217,0,0" VerticalAlignment="Top" Height="70" Width="170"/>

    </Grid>
</Window>
